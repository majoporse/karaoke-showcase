# Karaoke-Inator Frontend - Environment Configuration

# API Configuration
# URL of the Orchestrator Service API
VITE_API_URL=http://localhost:8000

# MinIO Configuration
# URL of the MinIO S3-compatible object storage
VITE_MINIO_URL=http://localhost:9000
VITE_MINIO_BUCKET=karaoke

# Application Settings
VITE_APP_NAME=SingSync

# Development
VITE_DEBUG=false
