  "components": {
    "schemas": {
      "Chunk": {
        "properties": {
          "start": {
            "type": "number",
            "title": "Start",
            "description": "Start time of the segment in seconds",
            "example": 0.0
          },
          "end": {
            "type": "number",
            "title": "End",
            "description": "End time of the segment in seconds",
            "example": 12.92
          },
          "text": {
            "type": "string",
            "title": "Text",
            "description": "Lyrics text for this segment",
            "example": "Wake up in the mornin' feelin' like P. Diddy"
          }
        },
        "type": "object",
        "required": [
          "start",
          "end",
          "text"
        ],
        "title": "Chunk"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
