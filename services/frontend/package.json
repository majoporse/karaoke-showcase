    "@react-router/node": "^7.13.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.31",
    "lucide-react": "^0.563.0",
    "minio": "^8.0.6",
    "partysocket": "^1.1.16",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "serve": "^14.2.5",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.4.0",
    "use-debounce": "^10.1.0",
    "uuid": "^13.0.0"
